# Copy this file to ".env" in the same folder and fill in your values.
# The file ".env" is gitignored — never commit real tokens.
#
# Hugging Face: https://huggingface.co/settings/tokens
# Use a token with "Read" (inference) or "Write" if you also push models.

# Same token the Hub uses elsewhere in this project (inference.py reads HF_TOKEN).
HF_TOKEN=

# If you set HF_TOKEN, you can leave LLM_API_KEY empty.
# LLM_API_KEY=

# OpenAI-compatible chat API (Hugging Face router for Option A)
LLM_BASE_URL=https://router.huggingface.co/v1

# Your merged model on the Hub, EXACT id from the model page / Inference example.
# Example format (replace with YOUR repo you pushed from Colab):
# LLM_MODEL=indra-dhanush/financial-triage-qwen-7b-merged:hf-inference
LLM_MODEL=

# Optional
# LLM_MAX_TOKENS=128
# LLM_TEMPERATURE=0.1
